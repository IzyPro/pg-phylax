# =============================================================
# PostgreSQL Backup to Cloudflare R2 - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# ---- PostgreSQL Connection ----------------------------------
POSTGRES_HOST=your-postgres-container-name
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
# Comma-separated for multiple: POSTGRES_DB=db1,db2,db3
POSTGRES_DB=your-database-name

# ---- Cloudflare R2 ------------------------------------------
# Account ID: Cloudflare Dashboard → R2 → Overview (right sidebar)
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=your-bucket-name
S3_PREFIX=postgres-backups
# Get from: R2 → Manage R2 API Tokens → Create API Token
# Permissions: Object Read & Write on your bucket
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_REGION=auto

# ---- Schedule -----------------------------------------------
# Standard cron expression or shortcut
# Examples:
#   0 2 * * *   → every day at 2:00 AM
#   0 */6 * * * → every 6 hours
#   @daily      → every day at midnight
#   @weekly     → every Sunday at midnight
#   @monthly    → 1st of every month at midnight
SCHEDULE=0 2 * * *
TZ=Africa/Lagos

# ---- Retention ----------------------------------------------
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=12

# ---- Telegram -----------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token
# Group chat ID - use @userinfobot to get it
# For groups the ID is negative: -1001234567890
TELEGRAM_CHAT_ID=your-chat-id

# ---- General ------------------------------------------------
SERVER_NAME=staging
